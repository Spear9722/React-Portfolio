{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sean-pearce-portfolio",
  "compatibility_date": "2026-07-17",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "frontend/dist",
    "not_found_handling": "single_page_application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
